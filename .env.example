DATABASE_URL=
# 実行エンジン = glot.io。https://glot.io/account/token で発行したトークン（クレカ不要）。
GLOT_TOKEN=
# 任意: glot エンドポイント上書き（既定は https://glot.io/api/run）。
# GLOT_URL=
PORT=
DEFAULT_USER_ID=
JWT_SECRET=
# development | production （production では JWT_SECRET 必須）
APP_ENV=
# 同一オリジンでフロントを配信する場合のビルド済みディレクトリ。
# 分離構成（フロント=Cloudflare Workers / API=Cloud Run）では空でよい。
STATIC_DIR=
# 別オリジンのフロントからの fetch を許可するオリジン（カンマ区切り）。
# 本番は Cloudflare Workers のURL。未設定だと "*"（全許可）。
ALLOWED_ORIGINS=

# PostgreSQL コンテナ初期化用 (docker-compose)
DB_NAME=
DB_USER=
DB_PASSWORD=
